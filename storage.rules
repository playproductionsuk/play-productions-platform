rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)); }
    function audioUnder(maxMb) { return request.resource.size < maxMb * 1024 * 1024 && request.resource.contentType.matches('audio/.*'); }
    match /covers/{all=**} { allow read: if true; allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*'); }
    match /previews/{all=**} { allow read: if true; allow write: if isAdmin() && audioUnder(30); }
    match /masters/{all=**} { allow read: if false; allow write: if isAdmin() && audioUnder(500); }
    match /case-studies/{all=**} { allow read: if true; allow write: if isAdmin() && audioUnder(100); }
    match /service-enquiries/{all=**} { allow read: if isAdmin(); allow create: if audioUnder(250); allow update, delete: if isAdmin(); }
    match /project-files/{uid}/{all=**} { allow read: if isAdmin() || (signedIn() && request.auth.uid == uid); allow write: if isAdmin() || (signedIn() && request.auth.uid == uid && audioUnder(500)); }
    match /final-files/{uid}/{all=**} { allow read: if isAdmin() || (signedIn() && request.auth.uid == uid); allow write: if isAdmin(); }
  }
}
