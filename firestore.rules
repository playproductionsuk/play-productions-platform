rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }

    match /tracks/{id} {
      allow read: if isAdmin() || resource.data.status in ['coming-soon', 'published'] || resource.data.showInDjPool == true;
      allow write: if isAdmin();
    }
    match /admins/{uid} { allow read: if owns(uid); allow write: if false; }
    match /users/{uid} { allow read: if owns(uid) || isAdmin(); allow create: if owns(uid); allow update: if owns(uid) || isAdmin(); allow delete: if isAdmin(); }
    match /orders/{id} { allow read: if isAdmin() || (signedIn() && resource.data.customerUid == request.auth.uid); allow write: if isAdmin(); }
    match /projects/{id} { allow read: if isAdmin() || (signedIn() && resource.data.customerUid == request.auth.uid); allow create: if signedIn() && request.resource.data.customerUid == request.auth.uid; allow update, delete: if isAdmin(); }
    match /enquiries/{id} {
      allow create: if request.resource.data.type is string
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 320
        && request.resource.data.keys().hasAll(['type', 'email', 'status', 'createdAt']);
      allow read, update, delete: if isAdmin();
    }
    match /tasks/{id} { allow read, write: if isAdmin(); }
    match /caseStudies/{id} { allow read: if resource.data.published == true || isAdmin(); allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /auditLog/{id} { allow read: if isAdmin(); allow write: if false; }
    match /purchases/{id} { allow read, write: if false; }
  }
}
